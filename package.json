{
  "name": "portfolio-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*",
    "../../timeline-backend/dev/packages/*"
  ],
  "scripts": {
    "next": "cd apps/portfolio && node -r ../../logger-patch.js ../../node_modules/next/dist/bin/next",
    "dev": "bun --filter @portfolio/app dev",
    "build": "bun --filter @portfolio/app build",
    "start": "bun --filter @portfolio/app start",
    "lint": "bun --filter @portfolio/app lint",
    "typecheck": "bun --filter @portfolio/app typecheck",
    "test": "bun --filter @portfolio/app test",
    "test:watch": "bun --filter @portfolio/app test:watch",
    "test:coverage": "bun --filter @portfolio/app test:coverage",
    "test:browser": "bun --filter @portfolio/app test:browser"
  },
  "devDependencies": {
    "stylis": "^4.3.6"
  }
}
